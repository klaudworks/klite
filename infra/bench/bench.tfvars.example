region          = "eu-west-1"
aws_profile     = "klite-bench"
ssh_public_key  = "ssh-ed25519 AAAA... your-email@example.com"

# MSK — disabled by default (takes ~20min, costs money)
enable_msk        = false
msk_instance_type = "kafka.m7g.large"
msk_broker_count  = 3

# EC2 (Graviton arm64)
klite_instance_type = "m7g.large"
bench_instance_type = "m7g.large"
