# Build stage
FROM golang:1.25-bookworm AS build

WORKDIR /src
COPY go.mod go.sum ./
RUN --mount=type=cache,target=/go/pkg/mod \
    go mod download

COPY . .
RUN --mount=type=cache,target=/go/pkg/mod \
    --mount=type=cache,target=/root/.cache/go-build \
    CGO_ENABLED=0 go build -ldflags "-s -w" -o /klite-bench ./cmd/klite-bench

# Runtime stage
FROM gcr.io/distroless/static-debian12

COPY --from=build /klite-bench /klite-bench

ENTRYPOINT ["/klite-bench"]
