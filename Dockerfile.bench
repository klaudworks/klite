# Build stage
FROM golang:1.25-bookworm AS build

WORKDIR /src
COPY go.mod go.sum ./
RUN go mod download

COPY . .
RUN CGO_ENABLED=0 go build -ldflags "-s -w" -o /klite-bench ./cmd/klite-bench

# Runtime stage
FROM gcr.io/distroless/static-debian12

COPY --from=build /klite-bench /klite-bench

ENTRYPOINT ["/klite-bench"]
